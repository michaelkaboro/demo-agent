<Window x:Class="TesterApp.GoodbyeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TesterApp - Goodbye"
        Width="500"
        Height="320"
        WindowStartupLocation="CenterScreen">
    <Grid Background="#FFF8FAFC" Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Button Width="100"
                Height="34"
                HorizontalAlignment="Left"
                Click="BackToMainButton_Click"
                Content="Back" />

        <Border Grid.Row="1"
                Margin="0,12,0,0"
                Padding="24"
                Background="White"
                BorderBrush="#CBD5E1"
                BorderThickness="1"
                CornerRadius="12">
            <StackPanel VerticalAlignment="Center">
                <TextBlock HorizontalAlignment="Center"
                           FontSize="30"
                           FontWeight="Bold"
                           Text="Goodbye!" />
                <TextBlock Margin="0,16,0,0"
                           HorizontalAlignment="Center"
                           FontSize="18"
                           Text="Thank you for using TesterApp." />
                <TextBlock Margin="0,10,0,0"
                           HorizontalAlignment="Center"
                           Foreground="#475569"
                           Text="We hope to see you again soon." />
            </StackPanel>
        </Border>
    </Grid>
</Window>
