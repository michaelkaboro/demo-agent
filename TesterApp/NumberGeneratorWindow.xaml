<Window x:Class="TesterApp.NumberGeneratorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TesterApp - Number Generator"
        Width="520"
        Height="560"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock FontSize="28"
                       FontWeight="Bold"
                       Text="Number Generator" />
            <Button Grid.Column="1"
                    Width="100"
                    Height="34"
                    Click="BackToMainButton_Click"
                    Content="Back" />
        </Grid>

        <TextBlock Grid.Row="1"
                   Margin="0,16,0,8"
                   Text="How many digits would you like to generate?" />

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal">
            <TextBox x:Name="CountTextBox"
                     Width="180"
                     Height="34"
                     VerticalContentAlignment="Center" />
            <Button Width="100"
                    Margin="12,0,0,0"
                    Click="GenerateButton_Click"
                    Content="Enter" />
        </StackPanel>

        <TextBox x:Name="OutputTextBox"
                 Grid.Row="3"
                 Margin="0,18,0,0"
                 Padding="12"
                 IsReadOnly="True"
                 AcceptsReturn="True"
                 VerticalScrollBarVisibility="Auto"
                 TextWrapping="Wrap" />
    </Grid>
</Window>
